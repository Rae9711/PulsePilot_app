{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd stream-2-frontend && npm ci",
  "buildCommand": "cd stream-2-frontend && npm run build",
  "outputDirectory": "stream-2-frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}