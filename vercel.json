{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix stream-2-frontend ci",
  "buildCommand": "npm --prefix stream-2-frontend run build",
  "outputDirectory": "stream-2-frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}